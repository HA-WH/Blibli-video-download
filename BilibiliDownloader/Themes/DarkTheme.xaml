<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bilibili 粉色主题色（浅色/深色通用） -->
    <Color x:Key="PrimaryColor">#FB7299</Color>
    <Color x:Key="PrimaryHoverColor">#E85C84</Color>
    <Color x:Key="PrimaryPressedColor">#D44A72</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#FB7299"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#E85C84"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#D44A72"/>

    <!-- 深色主题色 -->
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="CardColor">#2D2D2D</Color>
    <Color x:Key="BorderColor">#404040</Color>
    <Color x:Key="InputBorderColor">#404040</Color>
    <Color x:Key="TextPrimaryColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#999999</Color>
    <Color x:Key="TitleBarColor">#2D2D2D</Color>
    <Color x:Key="TitleBarTextColor">#E0E0E0</Color>
    <Color x:Key="ComboItemHoverColor">#3D2830</Color>
    <Color x:Key="ComboItemSelectedColor">#4D2838</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#404040"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#999999"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ComboItemHoverBrush" Color="#3D2830"/>
    <SolidColorBrush x:Key="ComboItemSelectedBrush" Color="#4D2838"/>

</ResourceDictionary>
