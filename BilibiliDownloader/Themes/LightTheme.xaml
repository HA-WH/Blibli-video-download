<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bilibili 粉色主题色（浅色/深色通用） -->
    <Color x:Key="PrimaryColor">#FB7299</Color>
    <Color x:Key="PrimaryHoverColor">#E85C84</Color>
    <Color x:Key="PrimaryPressedColor">#D44A72</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#FB7299"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#E85C84"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#D44A72"/>

    <!-- 浅色主题色 -->
    <Color x:Key="BackgroundColor">#FAFAFA</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="InputBorderColor">#E0E0E0</Color>
    <Color x:Key="TextPrimaryColor">#333333</Color>
    <Color x:Key="TextSecondaryColor">#888888</Color>
    <Color x:Key="TitleBarColor">#FB7299</Color>
    <Color x:Key="TitleBarTextColor">#FFFFFF</Color>
    <Color x:Key="ComboItemHoverColor">#FFF0F3</Color>
    <Color x:Key="ComboItemSelectedColor">#FFDCE5</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#333333"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="#FB7299"/>
    <SolidColorBrush x:Key="TitleBarTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboItemHoverBrush" Color="#FFF0F3"/>
    <SolidColorBrush x:Key="ComboItemSelectedBrush" Color="#FFDCE5"/>

</ResourceDictionary>
