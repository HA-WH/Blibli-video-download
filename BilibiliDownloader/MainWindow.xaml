<Window x:Class="BilibiliDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:BilibiliDownloader"
        mc:Ignorable="d"
        Title="BilibiliDownloader"
        Height="680" Width="600"
        MinHeight="560" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        Opacity="1">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <!-- 窗口加载淡入动画 -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{DynamicResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock Text="BilibiliDownloader"
                                   Foreground="{DynamicResource TitleBarTextBrush}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ThemeToggleButton" Content="&#x1F319;"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="ThemeToggle_Click"/>
                        <Button Content="&#x2500;"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="Minimize_Click"/>
                        <Button x:Name="MaximizeButton" Content="&#x25A1;"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="Maximize_Click"/>
                        <Button Content="&#x2715;"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Grid Grid.Row="1" Margin="36,28,36,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 可滚动输入区域 -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- 下载类型 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="3" Height="18" RadiusX="1.5" RadiusY="1.5"
                                       Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="下载类型" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <ComboBox x:Name="DownloadTypeCombo"
                                  SelectedIndex="2"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  SelectionChanged="Download_SelectionChanged"
                                  Margin="0,0,0,28">
                            <ComboBoxItem Content="&#x1F3B5; 仅音频"/>
                            <ComboBoxItem Content="&#x1F3AC; 仅视频"/>
                            <ComboBoxItem Content="&#x1F39E;&#xFE0F; 音视频"/>
                        </ComboBox>

                        <!-- 视频链接 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                                       Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="视频链接" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="UrlBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="0,0,10,0"/>
                            <Button Content="&#x00D7;" Grid.Column="1" Width="42"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ClearUrl_Click"/>
                        </Grid>

                        <!-- 保存路径 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                                       Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="保存路径" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PathBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     LostFocus="PathBox_LostFocus"
                                     Margin="0,0,10,0"/>
                            <Button x:Name="BrowseButton" Content="&#x1F4C2;"
                                    Grid.Column="1" Width="42"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="Browse_Click"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Rectangle Width="3" Height="14" RadiusX="1.5" RadiusY="1.5"
                                       Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Cookie" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CookieBox"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Margin="0,0,10,0"/>
                            <Button Content="&#x00D7;" Grid.Column="1" Width="42"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ClearCookie_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部：查询 + 下载按钮 + 状态 -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button x:Name="QueryButton" Content="🔍  查询音视频流"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Query_Click"/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="QualityCombo"
                                  Visibility="Collapsed"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Grid.Column="0" Margin="0,0,10,0"/>
                        <Button x:Name="DownloadButton" Content="⬇️  开始下载"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Grid.Column="1" Width="120"
                                IsEnabled="False"
                                Click="Download_Click"/>
                    </Grid>
                    <Grid x:Name="DualQualityGrid" Margin="0,16,0,0" Height="40" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="VideoQualityCombo"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Grid.Column="0" Margin="0,0,5,0"/>
                        <ComboBox x:Name="AudioQualityCombo"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  Grid.Column="1" Margin="5,0,0,0"/>
                    </Grid>
                    <TextBlock x:Name="StatusText"
                               Margin="0,16,0,0"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
